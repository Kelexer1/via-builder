{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "native-base",
            "hidden": true,
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/${presetName}"
        },
        {
            "name": "emscripten-base",
            "hidden": true,
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
            }
        },
        {
            "name": "native-debug",
            "inherits": "native-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "native-release",
            "inherits": "native-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "emscripten-debug",
            "inherits": "emscripten-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "emscripten-release",
            "inherits": "emscripten-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "native-debug",
            "configurePreset": "native-debug"
        },
        {
            "name": "native-release",
            "configurePreset": "native-release"
        },
        {
            "name": "emscripten-debug",
            "configurePreset": "emscripten-debug"
        },
        {
            "name": "emscripten-release",
            "configurePreset": "emscripten-release"
        }
    ],
    "workflowPresets": [
        {
            "name": "native-debug",
            "steps": [
                {
                    "type": "configure",
                    "name": "native-debug"
                },
                {
                    "type": "build",
                    "name": "native-debug"
                }
            ]
        },
        {
            "name": "native-release",
            "steps": [
                {
                    "type": "configure",
                    "name": "native-release"
                },
                {
                    "type": "build",
                    "name": "native-release"
                }
            ]
        },
        {
            "name": "emscripten-debug",
            "steps": [
                {
                    "type": "configure",
                    "name": "emscripten-debug"
                },
                {
                    "type": "build",
                    "name": "emscripten-debug"
                }
            ]
        },
        {
            "name": "emscripten-release",
            "steps": [
                {
                    "type": "configure",
                    "name": "emscripten-release"
                },
                {
                    "type": "build",
                    "name": "emscripten-release"
                }
            ]
        }
    ]
}